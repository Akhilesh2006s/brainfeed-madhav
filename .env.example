PORT=3001
NODE_ENV=production

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: API base URL for the frontend. Leave empty to use relative /api.
VITE_API_URL=

# MongoDB (logins / signups)
MONGO_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/your_database?appName=Cluster0

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=your_jwt_secret

# Admin credentials (first login with these creates the admin in MongoDB)
ADMIN_EMAIL=admin@brainfeed.com
ADMIN_PASSWORD=12345678
